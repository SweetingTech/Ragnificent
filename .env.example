API_HOST=0.0.0.0
API_PORT=8008
RAGNIFICENT_HOST_PORT=8008
API_KEY=change-me

LIBRARY_ROOT=D:/RAGLibrary
STATE_DB_PATH=D:/RAGLibrary/state/ingest.sqlite

POLL_INTERVAL_SECONDS=300

VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
COLLECTION_PREFIX=instance01

# Embeddings
EMBED_PROVIDER=ollama
EMBED_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text

# ---------------------------------------------------------------------------
# API Keys — fill in whichever providers you use, leave others blank
# ---------------------------------------------------------------------------

# OpenAI (embeddings + LLM: gpt-4o, gpt-4o-mini, text-embedding-3-small, etc.)
OPENAI_API_KEY=

# Anthropic Claude (LLM only: claude-3-5-sonnet-20241022, claude-3-opus, etc.)
ANTHROPIC_API_KEY=

# OpenRouter (embeddings + LLM: qwen/qwen3-embedding-8b, openai/gpt-4o, etc.)
OPENROUTER_API_KEY=
