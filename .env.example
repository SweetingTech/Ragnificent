API_HOST=127.0.0.1
API_PORT=8008
RAGNIFICENT_HOST_PORT=8008

# New machine-to-machine intake boundary. Generate a high-entropy value and
# share it only with the Agent Harness/AoJ service that publishes receipts.
# The source-receipt routes fail closed until this is set.
RAGNIFICENT_INTERNAL_TOKEN=

# Migration switch for legacy POST/DELETE routes. false keeps documented
# same-machine UI/local callers working; true requires X-Ragnificent-Token for
# all legacy API mutations as well.
RAGNIFICENT_REQUIRE_INTERNAL_AUTH=false

# Trust key for signed, redacted attestation files emitted only by the isolated
# JazzyMonitor private-evaluation runner. It verifies evidence; it never gives
# this service access to hidden cases or permission to promote a candidate.
# Configure the matching value through the runner host's file-mounted secret,
# not through JazzyMonitor's normal .env or Docker Compose environment.
RAGNIFICENT_PRIVATE_EVALUATION_ATTESTATION_KEY=

# Browser origins only. Server-to-server calls do not use CORS. Never use *.
RAGNIFICENT_CORS_ORIGINS=http://localhost:8018,http://127.0.0.1:8018,http://localhost:8008,http://127.0.0.1:8008,http://localhost:9002,http://127.0.0.1:9002

# Optional JSON mapping of logical source root IDs to server paths. When unset,
# only roots below LIBRARY_ROOT are accepted. Docker example:
# RAGNIFICENT_TRUSTED_SOURCE_ROOTS={"agent_harness_aar_sources":"/app/rag_library/agent_harness_aar_sources"}

# Required only for the dedicated voltron-repository-docs source-receipt lane.
# This is the path visible *inside the Ragnificent Docker container*. Compose
# bind-mounts the Windows host snapshot directory to it read-only. Do NOT set
# this to D:\Jazzy or another broad host workspace mount.
RAGNIFICENT_VOLTRON_REPOSITORY_DOCS_ROOT=/app/voltron-documentation-snapshots
# `voltron_repository_docs` is added from the value above. If you also include
# it in RAGNIFICENT_TRUSTED_SOURCE_ROOTS, it must resolve to this exact path.

# Empty by default: HTTP query callers use the configured corpus model and may
# not select arbitrary model IDs. Add only reviewed model IDs when needed.
RAGNIFICENT_ALLOWED_QUERY_MODEL_OVERRIDES=

LIBRARY_ROOT=D:/RAGLibrary
STATE_DB_PATH=D:/RAGLibrary/state/ingest.sqlite

POLL_INTERVAL_SECONDS=300

VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
COLLECTION_PREFIX=instance01

# Embeddings
EMBED_PROVIDER=ollama
EMBED_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text

# ---------------------------------------------------------------------------
# API Keys — fill in whichever providers you use, leave others blank
# ---------------------------------------------------------------------------

# OpenAI (embeddings + LLM: gpt-4o, gpt-4o-mini, text-embedding-3-small, etc.)
OPENAI_API_KEY=

# Anthropic Claude (LLM only: claude-3-5-sonnet-20241022, claude-3-opus, etc.)
ANTHROPIC_API_KEY=

# OpenRouter (embeddings + LLM: qwen/qwen3-embedding-8b, openai/gpt-4o, etc.)
OPENROUTER_API_KEY=
